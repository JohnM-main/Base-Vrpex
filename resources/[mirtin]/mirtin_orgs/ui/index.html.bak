<!doctype html>
<html lang="en">
   <meta http-equiv="content-type" content="text/html;charset=utf-8" />
   <head>
      <meta charset="utf-8">
      <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
      <script src="nui://game/ui/jquery.js" type="text/javascript"></script>
      <link href="style.css" type="text/css" rel="stylesheet">
      <script src="script.js" type="text/javascript"></script>

   </head>
   <body>
       
    <div class="mainContainer">
      <img class="logo" src="https://cdn.discordapp.com/attachments/900859265177239553/901222630378594355/Sem_Titulo-1.png">
      <div class="closeButton">X</div>

      <div class="titleContainer">
         <span id ="org">Organização: Nenhuma</span>
         <span id ="membros">Membros: 0/0</span>
     </div>

      <div class="containerMembers">

      </div>

      <div class="invite">
            <input placeholder="ID" type="number" id="inviteId">
            <button class="botao" id="convidar">Convidar</button>
      </div>

      <div class="anotacao">
            <textarea spellcheck="false" id="escrita"></textarea>
            <button id="anotar">Anotar</button>
      </div>

      <div class="buttons">
            <button class="botao desactive" id="promover">Promover</button>
            <button class="botao desactive" id="demitir">Demitir</button>
            <button class="pedirContas" id="pedircontas">Pedir Contas</button>
      </div>
    </div>
   </body>
</html>